<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Futuristic Galleries</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap" rel="stylesheet">
  <style>
    body {
      background: #0d0d0d;
      color: #fff;
      font-family: 'Orbitron', sans-serif;
      margin: 0;
      padding: 0;
    }
    h1 {
      text-align: center;
      padding: 20px;
      font-size: 2.5em;
      color: #00fff7;
      text-shadow: 0 0 10px #00fff7, 0 0 20px #00fff7;
    }
    .gallery-container {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 15px;
      padding: 20px;
    }
    .gallery-container img {
      width: 180px;
      height: 120px;
      object-fit: cover;
      border: 2px solid #00fff7;
      border-radius: 8px;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .gallery-container img:hover {
      transform: scale(1.1);
      box-shadow: 0 0 20px #00fff7;
    }
    .modal {
      display: none;
      position: fixed;
      z-index: 999;
      padding-top: 60px;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      overflow: auto;
      background-color: rgba(0,0,0,0.95);
    }
    .modal-content {
      margin: auto;
      display: block;
      max-width: 90%;
      max-height: 90%;
      border: 2px solid #00fff7;
      border-radius: 10px;
      animation: zoom 0.4s;
    }
    @keyframes zoom {
      from {transform: scale(0)}
      to {transform: scale(1)}
    }
    .close {
      position: absolute;
      top: 30px;
      right: 35px;
      color: #00fff7;
      font-size: 40px;
      font-weight: bold;
      cursor: pointer;
      transition: color 0.2s;
    }
    .close:hover {
      color: #ff00ff;
    }
    .gallery-title {
      width: 100%;
      text-align: center;
      font-size: 1.5em;
      margin-top: 40px;
      color: #ff00ff;
      text-shadow: 0 0 10px #ff00ff;
    }
  </style>
</head>
<body>

<h1>Futuristic Image Galleries</h1>

<!-- Gallery 1 -->
<div class="gallery-title">Gallery 1</div>
<div class="gallery-container" id="gallery1"></div>

<!-- Gallery 2 -->
<div class="gallery-title">Gallery 2</div>
<div class="gallery-container" id="gallery2"></div>

<!-- Gallery 3 -->
<div class="gallery-title">Gallery 3</div>
<div class="gallery-container" id="gallery3"></div>

<!-- Gallery 4 -->
<div class="gallery-title">Gallery 4</div>
<div class="gallery-container" id="gallery4"></div>

<!-- Modal -->
<div id="modal" class="modal">
  <span class="close">&times;</span>
  <img class="modal-content" id="modal-img">
</div>

<script>
  const galleries = {
    gallery1: [
      "1G1EzDxM4NgbDkHc6ykH1EFJwmlKERpQJ","17Wa9fOL0IERdZnxTrY1uXB7YBW1toFjY",
      "1N3U2aqkICzpjzXuNlxEko7XaLTygqs0q","1dH-tyPNwAB3HdfZBrRXC346LaLiiJ5qX",
